{
  "apps": [
    {
      "name": "bit-playground",
      "url": "https://abourdim.github.io/bit-playground/",
      "dismiss": "button:has-text(\"Let's Go\")",
      "autoButtons": true,
      "autoButtonsBlocklist": "🌙|⚡|☁️|🔥|beginner",
      "maxPages": 1,
      "preSteps": [
        {
          "action": "click",
          "selector": "button:has-text(\"expert\")"
        }
      ],
      "clicks": [
        "button.theme-btn.active",
        "button.theme-btn",
        "button.lang-btn.active",
        "button.lang-btn",
        "a:has-text(\"📖\")",
        "#clearCacheBtn",
        "#connectBtn",
        "#disconnectBtn",
        "#beginnerModeBtn",
        "#expertModeBtn",
        "#firmwareBtn",
        "#clearActivityBtn",
        "#controlsTabBtn",
        "#sensesTabBtn",
        "#servosTabBtn",
        "#gamepadTabBtn",
        "#graphTabBtn",
        "#board3dTabBtn",
        "#othersTabBtn",
        "#sendTextBtn",
        "#sendLedPatternBtn",
        "#clearMatrixBtn",
        "button.chip-btn.small",
        "#buzzLow",
        "#buzzMid",
        "#buzzHigh",
        "#buzzMelody",
        "#buzzPlay",
        "#buzzStop",
        "#onboardingDismiss"
      ],
      "clickMode": "independent"
    }
  ]
}
